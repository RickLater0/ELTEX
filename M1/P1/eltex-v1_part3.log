#использованные комманды 

mkdir D1/D2/D3
echo 'some trash' > D1/D2/file.txt
ln -s D1/D2/file.txt D1/D2/D3/soft
ln D1/D2/file.txt D1/D2/D3/hard
ls D1/D2/D3 -li
ls D1/D2 -li
mv D1/D2/file.txt D1/
cat D1/D2/D3/hard
cat D1/D2/D3/soft
find / -type f -size +20M -exec du -s -h {} + 2>/dev/null > ${USER}_part3_gt20M.log
find ~  -type f -mmin -1440 2>/dev/null
find / -type f -name find 2>/dev/null
file /usr/bin/find
file /usr/share/bash-completion/completions/find
file /boot/initrd.img*
